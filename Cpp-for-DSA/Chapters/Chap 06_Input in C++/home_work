#include <iostream>
#include <string>

using namespace std;

int main() {
    int age;
    string name;

    cout << "Enter your age: ";
    cin >> age; 

    // Checking if the user entered a non-integer (like letters)
    if (cin.fail()) {
        cout << "Invalid input! You did not enter a number." << endl;
        return 0;
    }

    // Clears the leftover Enter key (\n) from the buffer
    cin.ignore(); 

    cout << "Enter your full name: ";
    getline(cin, name); // This reads spaces too

    cout << "Hello " << name << ", you are " << age << " years old." << endl;
    return 0;
}
